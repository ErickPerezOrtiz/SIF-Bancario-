# ============================================================
#  Sistema de Inteligencia Financiera — Banca Dominicana
#  Configuración de entorno — copiar como .env y completar
# ============================================================

# -----------------------------------------------------------
# API — Superintendencia de Bancos de la República Dominicana
# Obtén tu clave en: https://desarrollador.sb.gob.do
# -----------------------------------------------------------
SB_API_KEY=TU_OCP_APIM_SUBSCRIPTION_KEY_AQUI
SB_BASE_URL=https://api.sb.gob.do/estadisticas/v2

# -----------------------------------------------------------
# Base de datos MySQL
# -----------------------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_NAME=sif_bancario
DB_USER=root
DB_PASSWORD=tu_password_mysql

# -----------------------------------------------------------
# Dashboard
# -----------------------------------------------------------
DASH_HOST=0.0.0.0
DASH_PORT=8050
DASH_DEBUG=False

# -----------------------------------------------------------
# ETL
# -----------------------------------------------------------
LOG_LEVEL=INFO
BATCH_SIZE=500
